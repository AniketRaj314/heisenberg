# OpenAI API key used for menu generation and conversational replies.
OPENAI_API_KEY=

# Token for the new Telegram bot created specifically for Heisenberg via @BotFather.
TELEGRAM_BOT_TOKEN=

# Numeric ID of the new Telegram group dedicated to Heisenberg (usually starts with -100).
TELEGRAM_CHAT_ID=

# Optional comma-separated Telegram user IDs allowed to control the bot.
# Leave empty only when every member of TELEGRAM_CHAT_ID is trusted.
TELEGRAM_ALLOWED_USER_IDS=

# Public Express health/API server port.
PORT=3000

# Required secret protecting the HTTP API. Generate with: openssl rand -hex 32
API_BEARER_TOKEN=

# Required secret protecting every MCP request. Generate with: openssl rand -hex 32
MCP_BEARER_TOKEN=

# Use "production" on Railway.
NODE_ENV=production

# Optional. Model used for constrained weekly menu generation.
OPENAI_MENU_MODEL=gpt-5.6-luna

# Optional. Stronger model used for Telegram conversation and tool calling.
OPENAI_AGENT_MODEL=gpt-5.6-terra

# Optional. Defaults to Asia/Kolkata.
TZ=Asia/Kolkata

# Optional JSON storage directory. Defaults to src/data.
# Railway volume mount: /app/src/data
DATA_DIR=
